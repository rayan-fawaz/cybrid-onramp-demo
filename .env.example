# ─── Cybrid Sandbox Credentials ──────────────────────────────
# Get these from your Cybrid dashboard → API Keys
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

CYBRID_ID_BASE_URL=https://id.sandbox.cybrid.app
CYBRID_BANK_BASE_URL=https://bank.sandbox.cybrid.app
CYBRID_BANK_CLIENT_ID=your_client_id_here
CYBRID_BANK_CLIENT_SECRET=your_client_secret_here
